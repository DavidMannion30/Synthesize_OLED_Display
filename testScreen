#include <Arduino.h>
#include <U8g2lib.h>
#include <SPI.h>

// Create display object (matches your wiring)
U8G2_SSD1309_128X64_NONAME0_F_4W_HW_SPI display(
  U8G2_R0,
  10, // CS
  9,  // DC
  8   // RESET
);


void setup() {
  display.begin();
  display.setFont(u8g2_font_ncenB08_tr);
}

void loop() {
  display.clearBuffer();
  display.drawStr(10, 30, "HELLO");
  display.sendBuffer();
}
