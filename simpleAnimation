#include <Arduino.h>
#include <U8g2lib.h>
#include <SPI.h>

U8G2_SSD1306_128X64_NONAME_F_4W_HW_SPI u8g2(U8G2_R0, 10, 9, 8);

int x = 0;

void setup() {
  u8g2.begin();
}

void loop() {
  u8g2.clearBuffer();
  u8g2.drawBox(x, 28, 16, 16);
  u8g2.sendBuffer();

  x += 2;
  if (x > 128) x = -16;

  delay(30);
}
