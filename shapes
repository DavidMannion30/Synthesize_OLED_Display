#include <Arduino.h>
#include <U8g2lib.h>
#include <SPI.h>

U8G2_SSD1306_128X64_NONAME_F_4W_HW_SPI u8g2(U8G2_R0, 10, 9, 8);

void setup() {
  u8g2.begin();
}

void loop() {
  u8g2.clearBuffer();

  u8g2.setFont(u8g2_font_6x10_tr);
  u8g2.drawStr(0, 12, "OLED works!");

  u8g2.drawFrame(0, 16, 128, 48);
  u8g2.drawBox(10, 26, 20, 12);
  u8g2.drawCircle(50, 32, 10);
  u8g2.drawLine(70, 22, 110, 50);

  u8g2.sendBuffer();
  delay(1000);
}
