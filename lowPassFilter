#include <Arduino.h>
#include <U8g2lib.h>
#include <SPI.h>

U8G2_SSD1306_128X64_NONAME_F_4W_HW_SPI u8g2(U8G2_R0, 10, 9, 8);

const int signalPin = 3;   // Output to circuit
const int sensePin  = A0;  // Measure output

const int numPoints = 64;

int amplitudes[numPoints];
int freqs[numPoints];


// Measure signal amplitude (peak-to-peak)
int measureAmplitude(int samples) {
  int minVal = 1023;
  int maxVal = 0;

  for (int i = 0; i < samples; i++) {
    int v = analogRead(sensePin);
    if (v < minVal) minVal = v;
    if (v > maxVal) maxVal = v;
  }

  return maxVal - minVal;
}


// Draw graph on OLED
void drawGraph() {
  u8g2.clearBuffer();

  // axes
  u8g2.drawLine(10, 60, 127, 60); // x-axis
  u8g2.drawLine(10, 0, 10, 60);   // y-axis

  u8g2.setFont(u8g2_font_5x7_tr);
  u8g2.drawStr(0, 8, "A");
  u8g2.drawStr(115, 63, "f");

  // find max amplitude
  int maxAmp = 1;
  for (int i = 0; i < numPoints; i++) {
    if (amplitudes[i] > maxAmp) maxAmp = amplitudes[i];
  }

  // plot graph
  for (int i = 0; i < numPoints - 1; i++) {
    int x1 = 10 + i * 117 / numPoints;
    int x2 = 10 + (i + 1) * 117 / numPoints;

    int y1 = 60 - map(amplitudes[i], 0, maxAmp, 0, 55);
    int y2 = 60 - map(amplitudes[i + 1], 0, maxAmp, 0, 55);

    u8g2.drawLine(x1, y1, x2, y2);
  }

  u8g2.sendBuffer();
}


void setup() {
  u8g2.begin();
  pinMode(signalPin, OUTPUT);
}


void loop() {

  // Sweep frequencies
  for (int i = 0; i < numPoints; i++) {

    int freq = 50 + i * 50;   // 50 Hz → ~3200 Hz
    freqs[i] = freq;

    tone(signalPin, freq);
    delay(20);

    amplitudes[i] = measureAmplitude(200);

    noTone(signalPin);
    delay(5);
  }

  drawGraph();

  delay(1000);
}
