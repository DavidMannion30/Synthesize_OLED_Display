#include <Arduino.h>
#include <U8g2lib.h>
#include <SPI.h>

U8G2_SSD1306_128X64_NONAME_F_4W_HW_SPI u8g2(U8G2_R0, 10, 9, 8);

const int signalPin   = 3;
const int buttonPin   = 2;
const int lowPassPin  = A0;
const int highPassPin = A1;

bool highPassMode = false;

// debounce
bool lastReading = HIGH;
bool buttonState = HIGH;
unsigned long lastDebounceTime = 0;
const unsigned long debounceDelay = 40;

// waveform buffer: one y-value for each x pixel
const int graphWidth = 128;
int waveY[graphWidth];

bool buttonPressed() {
  bool reading = digitalRead(buttonPin);

  if (reading != lastReading) {
    lastDebounceTime = millis();
  }

  if ((millis() - lastDebounceTime) > debounceDelay) {
    if (reading != buttonState) {
      buttonState = reading;
      if (buttonState == LOW) {
        lastReading = reading;
        return true;
      }
    }
  }

  lastReading = reading;
  return false;
}

void drawWaveform() {
  u8g2.clearBuffer();

  // title
  u8g2.setFont(u8g2_font_5x7_tr);
  if (highPassMode) {
    u8g2.drawStr(2, 7, "HIGH PASS");
  } else {
    u8g2.drawStr(2, 7, "LOW PASS");
  }

  // mid reference line
  u8g2.drawLine(0, 36, 127, 36);

  // waveform
  for (int x = 0; x < graphWidth - 1; x++) {
    u8g2.drawLine(x, waveY[x], x + 1, waveY[x + 1]);
  }

  u8g2.sendBuffer();
}

void setup() {
  u8g2.begin();
  pinMode(signalPin, OUTPUT);
  pinMode(buttonPin, INPUT_PULLUP);

  // choose one fixed frequency for real-time display
  tone(signalPin, 200);

  for (int i = 0; i < graphWidth; i++) {
    waveY[i] = 36;
  }
}

void loop() {
  if (buttonPressed()) {
    highPassMode = !highPassMode;
  }

  int readPin = highPassMode ? highPassPin : lowPassPin;

  // shift waveform left
  for (int i = 0; i < graphWidth - 1; i++) {
    waveY[i] = waveY[i + 1];
  }

  // read current sample
  int raw = analogRead(readPin);

  // map analog value to OLED y position
  // lower y = higher on screen
  int y = map(raw, 0, 1023, 63, 12);
  y = constrain(y, 12, 63);

  waveY[graphWidth - 1] = y;

  drawWaveform();

  delay(5);
}
