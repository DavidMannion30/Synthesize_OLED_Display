#include <Arduino.h>
#include <U8g2lib.h>
#include <SPI.h>

U8G2_SSD1306_128X64_NONAME_F_4W_HW_SPI u8g2(U8G2_R0, 10, 9, 8);

const int signalPin   = 3;
const int buttonPin   = 2;
const int lowPassPin  = A0;
const int highPassPin = A1;

const int numPoints = 64;
int amplitudes[numPoints];

bool highPassMode = false;
bool lastButtonState = HIGH;

int measureAverage(int pin, int samples) {
  long total = 0;
  for (int i = 0; i < samples; i++) {
    total += analogRead(pin);
  }
  return total / samples;
}

void drawGraph() {
  u8g2.clearBuffer();

  // axes
  u8g2.drawLine(10, 60, 127, 60);
  u8g2.drawLine(10, 10, 10, 60);

  u8g2.setFont(u8g2_font_5x7_tr);

  if (highPassMode)
    u8g2.drawStr(35, 8, "HIGH PASS");
  else
    u8g2.drawStr(38, 8, "LOW PASS");

  // FIXED SCALE (important)
  int minAmp = 0;
  int maxAmp = 1023;

  for (int i = 0; i < numPoints - 1; i++) {
    int x1 = 10 + (i * 117) / (numPoints - 1);
    int x2 = 10 + ((i + 1) * 117) / (numPoints - 1);

    int y1 = 60 - map(amplitudes[i], minAmp, maxAmp, 0, 48);
    int y2 = 60 - map(amplitudes[i + 1], minAmp, maxAmp, 0, 48);

    y1 = constrain(y1, 10, 60);
    y2 = constrain(y2, 10, 60);

    u8g2.drawLine(x1, y1, x2, y2);
  }

  u8g2.sendBuffer();
}

void measureFilter() {
  int readPin = highPassMode ? highPassPin : lowPassPin;

  for (int i = 0; i < numPoints; i++) {

    // VERY IMPORTANT: low frequencies
    int freq = 5 + i * 5;   // 5 Hz → ~320 Hz

    tone(signalPin, freq);
    delay(40);

    amplitudes[i] = measureAverage(readPin, 200);

    noTone(signalPin);
    delay(10);
  }

  drawGraph();
}

void setup() {
  u8g2.begin();
  pinMode(signalPin, OUTPUT);
  pinMode(buttonPin, INPUT_PULLUP);

  measureFilter();
}

void loop() {

  bool currentButtonState = digitalRead(buttonPin);

  if (lastButtonState == HIGH && currentButtonState == LOW) {
    highPassMode = !highPassMode;

    // small debounce
    delay(200);

    measureFilter();
  }

  lastButtonState = currentButtonState;
}
