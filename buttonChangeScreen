#include <Arduino.h>
#include <U8g2lib.h>
#include <SPI.h>

U8G2_SSD1306_128X64_NONAME_F_4W_HW_SPI u8g2(U8G2_R0, 10, 9, 8);

// Pins
const int buttonPin   = 2;
const int lowPassPin  = A0;
const int highPassPin = A1;

// Waveform settings
const int numSamples = 128;
int samples[numSamples];

bool showHighPass = false;
bool lastReading = HIGH;
bool buttonState = HIGH;

unsigned long lastDebounceTime = 0;
const unsigned long debounceDelay = 50;

// Sample spacing in microseconds
const unsigned int sampleDelayUs = 200;

void captureWaveform(int pin) {
  unsigned long startMicros = micros();

  for (int i = 0; i < numSamples; i++) {
    while ((micros() - startMicros) < (unsigned long)(i * sampleDelayUs)) {
      // wait
    }
    samples[i] = analogRead(pin);
  }
}

void drawWaveform() {
  u8g2.clearBuffer();
  u8g2.setFont(u8g2_font_5x7_tr);

  if (showHighPass) {
    u8g2.drawStr(38, 8, "HIGH PASS");
  } else {
    u8g2.drawStr(42, 8, "LOW PASS");
  }

  // graph area
  int top = 14;
  int bottom = 63;
  int height = bottom - top;

  u8g2.drawFrame(0, top, 128, height);
  u8g2.drawLine(0, top + height / 2, 127, top + height / 2);

  for (int i = 0; i < numSamples - 1; i++) {
    int x1 = i;
    int x2 = i + 1;

    int y1 = map(samples[i], 0, 1023, bottom - 1, top + 1);
    int y2 = map(samples[i + 1], 0, 1023, bottom - 1, top + 1);

    y1 = constrain(y1, top + 1, bottom - 1);
    y2 = constrain(y2, top + 1, bottom - 1);

    u8g2.drawLine(x1, y1, x2, y2);
  }

  u8g2.sendBuffer();
}

void checkButton() {
  bool reading = digitalRead(buttonPin);

  if (reading != lastReading) {
    lastDebounceTime = millis();
  }

  if ((millis() - lastDebounceTime) > debounceDelay) {
    if (reading != buttonState) {
      buttonState = reading;

      if (buttonState == LOW) {
        Serial.println("Button pressed");
        showHighPass = !showHighPass;

        if (showHighPass) {
          Serial.println("Showing HIGH PASS");
        } else {
          Serial.println("Showing LOW PASS");
        }
      } else {
        Serial.println("Button released");
      }
    }
  }

  lastReading = reading;
}

void setup() {
  Serial.begin(9600);

  pinMode(buttonPin, INPUT_PULLUP);

  u8g2.begin();

  Serial.println("OLED started");
  Serial.println("Initial mode: LOW PASS");

  // startup screen
  u8g2.clearBuffer();
  u8g2.setFont(u8g2_font_5x7_tr);
  u8g2.drawStr(20, 20, "Waveform Viewer");
  u8g2.drawStr(30, 35, "Starting...");
  u8g2.sendBuffer();
  delay(1000);
}

void loop() {
  checkButton();

  int activePin = showHighPass ? highPassPin : lowPassPin;
  captureWaveform(activePin);
  drawWaveform();
}
