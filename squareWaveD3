#include <Arduino.h>
#include <U8g2lib.h>
#include <SPI.h>

// ===== DISPLAY (your wiring) =====
U8G2_SSD1309_128X64_NONAME0_F_4W_HW_SPI display(
  U8G2_R0,
  10, // CS
  9,  // DC
  8   // RESET
);

// ===== SETTINGS =====
const int BUTTON_PIN = 2;
const int SIGNAL_OUT_PIN = 3;   // D3 = test signal output
const int CHANNEL_0 = A0;
const int CHANNEL_1 = A1;

int currentChannel = CHANNEL_0;

const int SCREEN_W = 128;
uint8_t waveform[SCREEN_W];

// Graph area
const int GRAPH_TOP = 10;
const int GRAPH_BOTTOM = 63;

// Adjust display sampling speed here
unsigned int sampleDelayUs = 1200;

// Test signal frequency
unsigned int testFrequencyHz = 250;

// Button debounce
bool lastButtonState = HIGH;
bool buttonState = HIGH;
unsigned long lastDebounceTime = 0;
const unsigned long debounceDelay = 50;

// ===== FUNCTIONS =====

// Shift waveform left
void shiftLeft() {
  for (int i = 0; i < SCREEN_W - 1; i++) {
    waveform[i] = waveform[i + 1];
  }
}

// Convert ADC -> screen Y
uint8_t adcToY(int val) {
  val = constrain(val, 0, 1023);
  return map(val, 0, 1023, GRAPH_BOTTOM, GRAPH_TOP);
}

// Convert ADC -> voltage
float adcToVoltage(int val) {
  return val * (5.0 / 1023.0);
}

// Draw grid
void drawGrid() {
  display.drawFrame(0, GRAPH_TOP, SCREEN_W, GRAPH_BOTTOM - GRAPH_TOP);

  int mid = (GRAPH_TOP + GRAPH_BOTTOM) / 2;
  for (int x = 0; x < SCREEN_W; x += 4) {
    display.drawPixel(x, mid);
  }

  for (int x = 16; x < SCREEN_W; x += 16) {
    for (int y = GRAPH_TOP; y < GRAPH_BOTTOM; y += 4) {
      display.drawPixel(x, y);
    }
  }
}

// Draw waveform
void drawWave() {
  for (int x = 0; x < SCREEN_W - 1; x++) {
    display.drawLine(x, waveform[x], x + 1, waveform[x + 1]);
  }
}

void clearWaveform() {
  uint8_t mid = (GRAPH_TOP + GRAPH_BOTTOM) / 2;
  for (int i = 0; i < SCREEN_W; i++) {
    waveform[i] = mid;
  }
}

void handleButton() {
  int reading = digitalRead(BUTTON_PIN);

  if (reading != lastButtonState) {
    lastDebounceTime = millis();
  }

  if ((millis() - lastDebounceTime) > debounceDelay) {
    if (reading != buttonState) {
      buttonState = reading;

      // Toggle channel on button press
      if (buttonState == LOW) {
        if (currentChannel == CHANNEL_0) {
          currentChannel = CHANNEL_1;
        } else {
          currentChannel = CHANNEL_0;
        }
        clearWaveform();
      }
    }
  }

  lastButtonState = reading;
}

// Generate square wave on D3
void generateSignal() {
  static unsigned long lastToggle = 0;
  static bool signalState = false;

  unsigned long halfPeriodUs = 1000000UL / (2UL * testFrequencyHz);
  unsigned long now = micros();

  if (now - lastToggle >= halfPeriodUs) {
    lastToggle = now;
    signalState = !signalState;
    digitalWrite(SIGNAL_OUT_PIN, signalState);
  }
}

// ===== SETUP =====
void setup() {
  pinMode(BUTTON_PIN, INPUT_PULLUP);
  pinMode(SIGNAL_OUT_PIN, OUTPUT);
  digitalWrite(SIGNAL_OUT_PIN, LOW);

  display.begin();
  display.setFont(u8g2_font_5x8_tf);

  clearWaveform();
}

// ===== LOOP =====
void loop() {
  generateSignal();
  handleButton();

  int val = analogRead(currentChannel);
  float voltage = adcToVoltage(val);

  shiftLeft();
  waveform[SCREEN_W - 1] = adcToY(val);

  display.clearBuffer();

  // Header line 1
  display.setCursor(0, 8);
  display.print("RC ");

  if (currentChannel == CHANNEL_0) {
    display.print("A0 ");
  } else {
    display.print("A1 ");
  }

  display.print(testFrequencyHz);
  display.print("Hz");

  // Header line 2
  display.setCursor(0, 16);
  display.print(voltage, 2);
  display.print("V");

  drawGrid();
  drawWave();

  display.sendBuffer();

  delayMicroseconds(sampleDelayUs);
}
